# SoulCodes Backend Environment Variables

# Notion Integration
NOTION_TOKEN=your_notion_integration_token_here
NOTION_TEMPLATES_DB_ID=your_templates_database_id
NOTION_ONBOARDING_DB_ID=your_onboarding_database_id
NOTION_BLUEPRINTS_DB_ID=your_blueprints_database_id

# Brevo Email Integration
BREVO_API_KEY=your_brevo_api_key_here

# Facebook Group Integration
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here
FACEBOOK_GROUP_ID=your_facebook_group_id_here

# Google Drive Integration
GOOGLE_SERVICE_ACCOUNT_FILE=path/to/your/service-account-key.json
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# Backend Configuration
PORT=8000
DEBUG=True
CORS_ORIGINS=["http://localhost:3000", "https://soulcodes.site", "https://digitallydefined.site"]

# Security
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

